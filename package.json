{
  "name": "gigaplan",
  "version": "0.4.1",
  "description": "Review agent-authored implementation plans in a GitHub-PR-style browser UI. Agents write plain Markdown; gigaplan renders, themes, and collects structured feedback.",
  "keywords": [
    "plan-review",
    "code-review",
    "claude-code",
    "markdown",
    "agent",
    "cli"
  ],
  "homepage": "https://github.com/corradodellorusso/gigaplan#readme",
  "bugs": "https://github.com/corradodellorusso/gigaplan/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/corradodellorusso/gigaplan.git"
  },
  "license": "MIT",
  "author": "Corrado dello Russo <info@corradodellorusso.it>",
  "type": "module",
  "bin": {
    "gigaplan": "bin/gigaplan.js"
  },
  "files": [
    "bin",
    "dist",
    "public",
    "skills"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.server.json && tsc -p tsconfig.client.json",
    "prepare": "npm run build",
    "typecheck": "tsc --noEmit -p tsconfig.server.json && tsc --noEmit -p tsconfig.client.json",
    "test": "node --import tsx --test test/*.test.ts",
    "test:ui": "node --import tsx --test test/ui/*.test.ts"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "express": "^5.2.1",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.3.0",
    "open": "^11.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.13.3",
    "playwright": "^1.61.1",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  }
}
